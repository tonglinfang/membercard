# ── LINE LIFF Configuration ──────────────────────────────────────────────────
# 1. Go to https://developers.line.biz/ → Your channel → LIFF
# 2. Create a new LIFF app with "Full" size and the correct Endpoint URL
# 3. Copy the generated LIFF ID and paste it below
# 4. Rename this file to .env (or .env.local) before running the app

REACT_APP_LIFF_ID=your-liff-id-here
